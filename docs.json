{
  "theme": "mint",
  "name": "ShardCloud",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "mdx": {
      "server": "https://api.phanomcloud.online",
      "auth": {
        "method": "bearer",
        "name": null
      }
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://shardcloud.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://shardcloud.app"
    }
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/shardcloud"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Support",
          "icon": "discord",
          "href": "https://discord.gg/shardcloud"
        },
        {
          "anchor": "Status",
          "icon": "signal",
          "href": "https://status.shardcloud.app"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "authentication",
